<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D18"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/sky_header_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/sky_mid_blue"
            android:text="&#9664; BACK"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="BUBBLE SHOOTER"
            android:textColor="@color/sky_yellow"
            android:textSize="15sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold" />

        <!-- Score panel -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORE"
                android:textColor="@color/sky_cyan"
                android:textSize="9sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/sky_yellow"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL"
                android:textColor="@color/sky_cyan"
                android:textSize="9sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/sky_white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_new_game"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#223355"
            android:text="NEW"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="12dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/sky_cyan" />

    <!-- Status / message bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:background="#0A1A30"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AIM WITH LEFT / RIGHT · FIRE WITH OK"
            android:textColor="@color/sky_light_blue"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed" />

        <TextView
            android:id="@+id/tv_best"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BEST: 0"
            android:textColor="#668899"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <!-- Game view -->
    <com.skyretro.iptv.ui.games.BeehiveView
        android:id="@+id/beehive_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
