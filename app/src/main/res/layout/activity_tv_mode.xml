<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video surface -->
    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:clickable="true" />

    <!-- ── HUD top bar ── buttons -->
    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#D0000D22"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_hud_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_back"
            android:text="⬅  MENU"
            android:textColor="@color/sky_white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/sky_cyan"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_hud_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="AUDIO"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#8B0000"
            android:text="● REC"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_scores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="SCORES"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_news"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="NEWS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ── Bottom stack: HUD info bar + ticker rows ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- HUD bottom info bar -->
        <LinearLayout
            android:id="@+id/hud_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/orbital_dark_blue"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/sky_cyan" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#07121F"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tv_hud_channel_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/sky_white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AABBCC"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.03" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A4590"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="NOW"
                    android:textColor="@color/sky_cyan"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tv_epg_now"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/sky_white"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/live_next_row"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#07121F"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_epg_next_time"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/sky_cyan"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.03" />

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="NEXT"
                    android:textColor="#7799BB"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tv_epg_next_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#AABBCC"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- News headlines ticker -->
        <FrameLayout
            android:id="@+id/news_ticker_row"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD001008"
            android:clipChildren="true"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_news_ticker"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor="#FFCC00"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:singleLine="true"
                android:focusable="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical" />
        </FrameLayout>

        <!-- Sports scores ticker -->
        <FrameLayout
            android:id="@+id/ticker_row"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD000A1A"
            android:clipChildren="true"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_ticker"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor="#00CCCC"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:singleLine="true"
                android:focusable="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical" />
        </FrameLayout>

    </LinearLayout>

    <!-- ── EPG + Nav overlay (shown when LEFT is pressed while watching) ── -->
    <FrameLayout
        android:id="@+id/epg_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Main menu panel (leftmost, shown on second LEFT from categories) -->
            <LinearLayout
                android:id="@+id/main_menu_panel"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#F5020C1C"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:background="#FF010810">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORBITAL"
                        android:textColor="@color/sky_cyan"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/sky_cyan" />

                <TextView android:id="@+id/menu_item_live_tv"
                    android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                    android:text="LIVE TV" android:textColor="@color/sky_white" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" android:letterSpacing="0.06"
                    android:gravity="center" android:focusable="true" android:clickable="true" android:background="#0A1628" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A3560" />

                <TextView android:id="@+id/menu_item_box_office"
                    android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                    android:text="BOX OFFICE" android:textColor="@color/sky_white" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" android:letterSpacing="0.06"
                    android:gravity="center" android:focusable="true" android:clickable="true" android:background="#0D1E38" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A3560" />

                <TextView android:id="@+id/menu_item_radio"
                    android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                    android:text="RADIO" android:textColor="@color/sky_white" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" android:letterSpacing="0.06"
                    android:gravity="center" android:focusable="true" android:clickable="true" android:background="#0A1628" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A3560" />

                <TextView android:id="@+id/menu_item_interactive"
                    android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                    android:text="INTERACTIVE" android:textColor="@color/sky_white" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" android:letterSpacing="0.06"
                    android:gravity="center" android:focusable="true" android:clickable="true" android:background="#0D1E38" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A3560" />

                <TextView android:id="@+id/menu_item_settings"
                    android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                    android:text="SETTINGS" android:textColor="@color/sky_white" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" android:letterSpacing="0.06"
                    android:gravity="center" android:focusable="true" android:clickable="true" android:background="#0A1628" />

            </LinearLayout>

            <!-- Divider between main menu and categories -->
            <View
                android:id="@+id/main_menu_divider"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="@color/sky_cyan"
                android:visibility="gone" />

            <!-- Category list (always visible when overlay is open) -->
            <ScrollView
                android:id="@+id/tv_cat_scroll"
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:background="#F0060C1A"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/tv_cat_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp" />

            </ScrollView>

            <!-- Divider between categories and EPG -->
            <View
                android:id="@+id/cat_epg_divider"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="@color/sky_cyan"
                android:visibility="gone" />

            <!-- Now & Next panel (shown in EPG state, hidden in MAIN_MENU state) -->
            <LinearLayout
                android:id="@+id/epg_panel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#0A1628"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_now_next_header"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:text="NOW &amp; NEXT"
                    android:textColor="@color/sky_yellow"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_now_next"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
