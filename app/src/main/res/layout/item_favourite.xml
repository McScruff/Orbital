<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="@color/sky_dark_blue">

    <!-- Art thumbnail -->
    <ImageView
        android:id="@+id/iv_art"
        android:layout_width="54dp"
        android:layout_height="72dp"
        android:scaleType="centerCrop"
        android:background="#111827" />

    <!-- Left accent bar -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/sky_cyan" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sky_white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sky_cyan"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Progress bar (visible only for resume items) -->
        <FrameLayout
            android:id="@+id/progress_container"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:background="#1A3A6A"
            android:visibility="gone">

            <View
                android:id="@+id/progress_fill"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/sky_yellow" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_resume_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sky_yellow"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Right badge -->
    <TextView
        android:id="@+id/tv_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#9654;"
        android:textColor="@color/sky_dark_blue"
        android:textSize="12sp"
        android:fontFamily="sans-serif-condensed"
        android:textStyle="bold"
        android:background="@color/sky_yellow"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginEnd="8dp" />

</LinearLayout>
