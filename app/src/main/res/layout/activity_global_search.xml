<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#0D1B35"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="◀ BACK"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#1A3560"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SEARCH"
            android:textColor="#E5A00D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/tv_result_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AABBCC"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Accent line -->
    <View
        android:id="@+id/view_accent"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#E5A00D" />

    <!-- Search row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111F3A"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 "
            android:textSize="16sp"
            android:textColor="#E5A00D" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="SEARCH TV, MOVIES &amp; SERIES ACROSS ALL SOURCES..."
            android:textColorHint="#557799"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@null"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

    <!-- Filter bar: EVERYTHING · TV · MOVIES ONLY · SERIES ONLY -->
    <LinearLayout
        android:id="@+id/filter_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#0D1B35"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_filter_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="EVERYTHING"
            android:textSize="9sp"
            android:background="#E5A00D"
            android:focusable="true"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_filter_tv"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="TV"
            android:textSize="9sp"
            android:background="#1A3560"
            android:focusable="true"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_filter_movies"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MOVIES ONLY"
            android:textSize="9sp"
            android:background="#1A3560"
            android:focusable="true"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_filter_series"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="SERIES ONLY"
            android:textSize="9sp"
            android:background="#1A3560"
            android:focusable="true" />

    </LinearLayout>

    <!-- Loading bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:indeterminateTint="#E5A00D"
        android:visibility="gone" />

    <!-- Results row: sidebar + grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left sidebar: source breakdown -->
        <ScrollView
            android:id="@+id/sidebar_scroll"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/sidebar_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp" />

        </ScrollView>

        <!-- Results grid / empty state -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp"
                android:clipToPadding="false"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="TYPE TO SEARCH TV, MOVIES &amp; SERIES ACROSS ALL SOURCES"
                android:textColor="#557799"
                android:textSize="14sp"
                android:visibility="visible" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
