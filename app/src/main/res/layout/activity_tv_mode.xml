<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video surface -->
    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:clickable="true" />

    <!-- ── HUD top bar ── buttons (mirrors PlayerActivity hud_overlay) -->
    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#D0000D22"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_hud_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_back"
            android:text="⬅  MENU"
            android:textColor="@color/sky_white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/sky_cyan"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_hud_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="AUDIO"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#8B0000"
            android:text="● REC"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_scores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="SCORES"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_hud_news"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="NEWS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ── Bottom stack: HUD info bar + ticker rows ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- HUD bottom info bar (mirrors PlayerActivity bottom_bar) -->
        <LinearLayout
            android:id="@+id/hud_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/orbital_dark_blue"
            android:visibility="gone">

            <!-- Thin cyan top accent line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/sky_cyan" />

            <!-- Row 1: channel name (left) + clock (right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#07121F"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tv_hud_channel_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/sky_white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AABBCC"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.03" />

            </LinearLayout>

            <!-- Row 2: NOW programme -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A4590"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="NOW"
                    android:textColor="@color/sky_cyan"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tv_epg_now"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/sky_white"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Row 3: NEXT programme -->
            <LinearLayout
                android:id="@+id/live_next_row"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#07121F"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_epg_next_time"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/sky_cyan"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.03" />

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="NEXT"
                    android:textColor="#7799BB"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/tv_epg_next_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#AABBCC"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- News headlines ticker -->
        <FrameLayout
            android:id="@+id/news_ticker_row"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD001008"
            android:clipChildren="true"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_news_ticker"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor="#FFCC00"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:singleLine="true"
                android:focusable="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical" />
        </FrameLayout>

        <!-- Sports scores ticker -->
        <FrameLayout
            android:id="@+id/ticker_row"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD000A1A"
            android:clipChildren="true"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_ticker"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor="#00CCCC"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:singleLine="true"
                android:focusable="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical" />
        </FrameLayout>

    </LinearLayout>

    <!-- ── Left-panel overlay (CHANNELS / CATEGORIES) ── -->
    <FrameLayout
        android:id="@+id/overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Left panel -->
        <LinearLayout
            android:id="@+id/left_panel"
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#F0060C1A">

            <!-- Header: back-to-menu button + panel title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FF010810"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <Button
                    android:id="@+id/btn_back_to_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="⬅ MENU"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#1A3560"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_panel_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CHANNELS"
                    android:textColor="#E5A00D"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:paddingStart="8dp" />

            </LinearLayout>

            <!-- Accent line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#3A9EFF" />

            <!-- Channel / Category list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Right side: semi-transparent, clicking closes the overlay -->
        <View
            android:id="@+id/overlay_dismiss"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="340dp"
            android:background="#55000000"
            android:clickable="true"
            android:focusable="false" />

    </FrameLayout>

</FrameLayout>
