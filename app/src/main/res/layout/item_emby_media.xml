<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:background="#0D1B35"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp">

        <ImageView
            android:id="@+id/iv_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#0D1B35" />

        <!-- Resolution badge: top-right corner of poster -->
        <TextView
            android:id="@+id/tv_resolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:background="#CC000000"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#E5A00D"
            android:textSize="8sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Watch progress strip at bottom of poster -->
        <ProgressBar
            android:id="@+id/progress_watched"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/sky_cyan"
            android:progressBackgroundTint="#44FFFFFF"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:textColor="@color/sky_white"
        android:textSize="10sp"
        android:fontFamily="sans-serif-condensed"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp"
        android:textColor="@color/sky_yellow"
        android:textSize="9sp"
        android:fontFamily="sans-serif-condensed"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
