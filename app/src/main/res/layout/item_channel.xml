<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Channel Number -->
    <TextView
        android:id="@+id/tv_channel_number"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#AABBCC"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:background="#0A1525" />

    <!-- Channel Icon -->
    <ImageView
        android:id="@+id/iv_channel_icon"
        android:layout_width="40dp"
        android:layout_height="28dp"
        android:scaleType="centerInside"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp" />

    <!-- Channel Name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sky_white"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_epg_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#88AAAAAA"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="LOADING EPG..." />
    </LinearLayout>

    <!-- Live indicator dot -->
    <View
        android:layout_width="7dp"
        android:layout_height="7dp"
        android:background="@drawable/bg_live_dot"
        android:layout_marginEnd="12dp" />

</LinearLayout>
