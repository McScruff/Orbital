<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbital_dark_blue"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/sky_header_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="@color/orbital_dark_blue"
            android:gravity="center"
            android:orientation="vertical">
<ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/orbital_logo"
                android:scaleType="fitCenter"
                android:contentDescription="Orbital" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="&#9664; TV GUIDE"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="INTERACTIVE"
            android:textColor="@color/sky_yellow"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:background="@color/sky_tab_selected" />

    </LinearLayout>

    <View
        android:id="@+id/view_accent"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/sky_cyan" />

    <!-- Section header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/sky_mid_blue"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="GAMES"
        android:textColor="@color/sky_yellow"
        android:textSize="13sp"
        android:fontFamily="sans-serif-condensed"
        android:textStyle="bold" />

    <!-- Games list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sports Scores tile -->
            <LinearLayout
                android:id="@+id/tile_sports"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#0D3A1A"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9917;"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPORTS SCORES"
                        android:textColor="@color/sky_yellow"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live scores, fixtures &amp; league tables"
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN &#9654;"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="@color/sky_yellow"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

            <!-- Sky Sports News Ticker tile -->
            <LinearLayout
                android:id="@+id/tile_news_ticker"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#00112A"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128240;"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPORTS NEWS TICKER  — TAP TO SELECT SPORTS"
                        android:textColor="@color/sky_yellow"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_news_ticker_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show latest sports headlines while watching"
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btn_news_ticker_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFF"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="@color/sky_yellow"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:clickable="true"
                    android:focusable="false" />

            </LinearLayout>

            <!-- Teletext Sports News tile -->
            <LinearLayout
                android:id="@+id/tile_teletext"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#000044"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P301"
                        android:textColor="#FFFF00"
                        android:textSize="16sp"
                        android:typeface="monospace"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TELETEXT SPORTS NEWS"
                        android:textColor="@color/sky_yellow"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ceefax-style BBC Sport headlines by sport"
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN &#9654;"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="@color/sky_yellow"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

            <!-- Emby tile -->
            <LinearLayout
                android:id="@+id/tile_emby"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#52B54B"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="e"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMBY"
                        android:textColor="@color/sky_yellow"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Browse your Emby media server — movies, TV and music"
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN &#9654;"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="@color/sky_yellow"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

            <!-- Plex tile -->
            <LinearLayout
                android:id="@+id/tile_plex"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#E5A00D"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9654;"
                        android:textColor="#1A1A1A"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLEX"
                        android:textColor="#E5A00D"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Browse your Plex media server — movies, TV and music"
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN &#9654;"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="#E5A00D"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

            <!-- Bubble Shooter tile -->
            <LinearLayout
                android:id="@+id/tile_bubble"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="#FFCC00"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x2B22;"
                        android:textSize="28sp"
                        android:textColor="#FF8800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUBBLE SHOOTER"
                        android:textColor="@color/sky_yellow"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shoot coloured bubbles and match 3 or more!\nAim with the D-pad, fire with OK."
                        android:textColor="@color/sky_white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAY &#9654;"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:background="@color/sky_yellow"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0D1A2E"
        android:gravity="center_vertical"
        android:paddingStart="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ORBITAL  •  INTERACTIVE"
            android:textColor="#668899"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed" />
    </LinearLayout>

</LinearLayout>
