<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_dark_blue"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/sky_header_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="@color/sky_dark_blue"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sky"
                android:textColor="@color/sky_cyan"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="&#9664; SETTINGS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CATEGORY EDITOR"
            android:textColor="@color/sky_yellow"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:background="@color/sky_tab_selected" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/sky_cyan" />

    <!-- Two-panel content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- LEFT: Sky categories -->
        <ScrollView
            android:layout_width="240dp"
            android:layout_height="match_parent"
            android:background="@color/sky_dark_blue"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@color/sky_yellow"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:text="SKY CATEGORIES"
                    android:textColor="@color/sky_dark_blue"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:text="TAP TO RENAME"
                    android:textColor="#AACCDD"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-condensed" />

                <LinearLayout
                    android:id="@+id/sky_cat_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/sky_cyan" />

        <!-- RIGHT: Server categories -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="SERVER CATEGORIES  —  TAP TO REASSIGN"
                android:textColor="@color/sky_yellow"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/server_cat_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0D1A2E"
        android:gravity="center_vertical"
        android:paddingStart="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKY DIGITAL  •  CATEGORY EDITOR"
            android:textColor="#668899"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed" />
    </LinearLayout>

</LinearLayout>
