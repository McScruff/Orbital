<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_dark_blue"
    android:orientation="vertical">

    <!-- Top nav bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/sky_header_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="@color/sky_dark_blue"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sky"
                android:textColor="@color/sky_cyan"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="&#9664; CATCHUP"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text=""
            android:textColor="@color/sky_yellow"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:background="@color/sky_tab_selected"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <View
        android:id="@+id/view_accent"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/sky_cyan" />

    <!-- Day tab strip -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:scrollbars="none"
        android:background="#0D1A2E">

        <LinearLayout
            android:id="@+id/day_tab_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/sky_mid_blue" />

    <!-- Programme list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_programmes"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/sky_cyan"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#668899"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0D1A2E"
        android:gravity="center_vertical"
        android:paddingStart="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKY DIGITAL  •  CATCHUP TV"
            android:textColor="#668899"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed" />
    </LinearLayout>

</LinearLayout>
