<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Orbital" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/orbital_dark_blue</item>
        <item name="colorPrimaryDark">@color/orbital_dark_blue</item>
        <item name="colorAccent">@color/sky_cyan</item>
        <item name="android:windowBackground">@color/orbital_dark_blue</item>
        <item name="android:statusBarColor">@color/orbital_dark_blue</item>
        <item name="android:navigationBarColor">@color/orbital_dark_blue</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.Orbital.Dialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="android:textColorPrimary">@color/sky_white</item>
        <item name="android:colorAccent">@color/sky_cyan</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Selected at runtime via ThemeManager.dialogStyle() when the BLACK & WHITE app theme is
         active — AlertDialog styles are static XML and can't read the Kotlin palette directly,
         so every AlertDialog.Builder(context, R.style...) call site uses that helper instead of
         referencing either style name directly. -->
    <style name="Theme.Orbital.Dialog.Mono" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_mono</item>
        <item name="android:textColorPrimary">@color/sky_white</item>
        <item name="android:colorAccent">#FFFFFF</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
