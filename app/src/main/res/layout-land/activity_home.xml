<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbital_dark_blue"
    android:orientation="vertical">

    <!-- ═══ TOP NAV BAR ═══ -->
    <LinearLayout
        android:id="@+id/layout_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/sky_header_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Orbital Logo -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="@color/orbital_dark_blue"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/orbital_logo"
                android:scaleType="fitCenter"
                android:contentDescription="Orbital" />
        </LinearLayout>

        <!-- Top Nav Tabs -->
        <TextView
            android:id="@+id/tab_tv_guide"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="TV GUIDE"
            android:textColor="@color/sky_yellow"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:background="@color/sky_tab_selected"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusDown="@id/cat_entertainment" />

        <TextView
            android:id="@+id/tab_box_office"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="BOX OFFICE"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusDown="@id/cat_entertainment" />

        <TextView
            android:id="@+id/tab_radio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="RADIO"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusDown="@id/cat_entertainment" />

        <TextView
            android:id="@+id/tab_interactive"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="INTERACTIVE"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusDown="@id/cat_entertainment" />

        <TextView
            android:id="@+id/tab_services"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SETTINGS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:background="@color/sky_header_blue"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusDown="@id/cat_entertainment" />
    </LinearLayout>

    <View
        android:id="@+id/view_top_accent"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/sky_cyan" />

    <!-- ═══ MAIN CONTENT ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- LEFT: Category Menu -->
        <ScrollView
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="@color/orbital_dark_blue"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/header_tv_listings"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@color/sky_yellow"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  1  TV GUIDE"
                    android:textColor="@color/orbital_dark_blue"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/tab_tv_guide"
                    android:nextFocusDown="@id/cat_entertainment"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_entertainment"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  2  ENTERTAINMENT"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/header_tv_listings"
                    android:nextFocusDown="@id/cat_movies"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_movies"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/orbital_dark_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  3  MOVIES"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_entertainment"
                    android:nextFocusDown="@id/cat_sports"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_sports"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  4  SPORTS"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_movies"
                    android:nextFocusDown="@id/cat_news"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_news"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/orbital_dark_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  5  NEWS"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_sports"
                    android:nextFocusDown="@id/cat_children"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_children"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  6  CHILDREN"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_news"
                    android:nextFocusDown="@id/cat_music"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_music"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/orbital_dark_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  7  MUSIC"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_children"
                    android:nextFocusDown="@id/cat_other"
                    android:nextFocusRight="@id/rv_channels" />

                <TextView
                    android:id="@+id/cat_other"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/sky_mid_blue"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="  8  OTHER"
                    android:textColor="@color/sky_white"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:focusable="true"
                    android:clickable="true"
                    android:nextFocusUp="@id/cat_music"
                    android:nextFocusRight="@id/rv_channels" />

                <LinearLayout
                    android:id="@+id/original_cat_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <View
            android:id="@+id/view_vertical_divider"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/sky_cyan" />

        <!-- RIGHT: Channel List -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_current_category"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@color/sky_mid_blue"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="ENTERTAINMENT"
                android:textColor="@color/sky_yellow"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_margin="10dp" />

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFF4444"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:visibility="gone"
                android:padding="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:nextFocusLeft="@id/cat_entertainment" />
        </LinearLayout>
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0D1A2E"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORBITAL  •  USE ARROWS TO NAVIGATE"
            android:textColor="#668899"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed" />
        <TextView
            android:id="@+id/tv_channel_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 CHANNELS"
            android:textColor="@color/sky_cyan"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed" />
    </LinearLayout>

</LinearLayout>
