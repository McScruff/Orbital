<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video surface (ExoPlayer — live TV) -->
    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- MPV surface (movies and series — all codecs) -->
    <com.skyretro.iptv.ui.player.SkyMpvView
        android:id="@+id/mpv_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Top HUD overlay -->
    <LinearLayout
        android:id="@+id/hud_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D0000D22"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_back"
            android:text="◄  BACK"
            android:textColor="@color/sky_white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_player_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text=""
            android:textColor="@color/sky_cyan"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="AUDIO"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_subs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="SUBS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_scores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="SCORES"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_news"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="NEWS"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_open_in"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_hud"
            android:text="OPEN IN"
            android:textColor="@color/sky_white"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="14dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONNECTING..."
            android:textColor="@color/sky_yellow"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- Bottom Sky-style info bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/sky_dark_blue"
        android:visibility="gone">

        <!-- Thin cyan top accent line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sky_cyan" />

        <!-- Row 1: channel info (left) + clock (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#07121F"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tv_channel_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/sky_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AABBCC"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.03" />

        </LinearLayout>

        <!-- Row 2: NOW programme (live TV only) -->
        <LinearLayout
            android:id="@+id/live_now_row"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A4590"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_now_label"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:text="NOW"
                android:textColor="@color/sky_cyan"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tv_now_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/sky_white"
                android:textSize="15sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Row 3: NEXT programme (live TV only) -->
        <LinearLayout
            android:id="@+id/live_next_row"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#07121F"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_next_time"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="@color/sky_cyan"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.03" />

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="NEXT"
                android:textColor="#7799BB"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <TextView
                android:id="@+id/tv_next_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#AABBCC"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Row 4: VOD seek controls (movies & series only) -->
        <LinearLayout
            android:id="@+id/vod_seek_row"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0B1A30"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btn_seek_back"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="◄◄  -30s"
                android:textColor="@color/sky_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_seek"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="▌▌  PAUSE"
                android:textColor="@color/sky_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_seek"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0:00 / 0:00"
                android:textColor="#BBCCDD"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/btn_seek_fwd"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+30s  ▶▶"
                android:textColor="@color/sky_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_seek"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Thin progress bar (VOD only) -->
        <ProgressBar
            android:id="@+id/vod_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="1000"
            android:progress="0"
            android:progressTint="@color/sky_cyan"
            android:progressBackgroundTint="#102040"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Buffering spinner -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/sky_cyan" />

    <!-- Ticker container: news on top, scores on bottom; each row independent -->
    <LinearLayout
        android:id="@+id/ticker_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_news_ticker"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD001008"
            android:textColor="#FFCC00"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:focusable="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_ticker"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#DD000A1A"
            android:textColor="#00CCCC"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:focusable="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Seek scrub indicator (centred, shown while scrubbing) -->
    <LinearLayout
        android:id="@+id/seek_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_seek_panel"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_seek_direction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶▶"
            android:textColor="@color/sky_cyan"
            android:textSize="20sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_seek_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/sky_white"
            android:textSize="48sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
